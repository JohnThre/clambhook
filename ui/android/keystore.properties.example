# Release signing config for the ClambHook Android app.
#
# ClambHook is distributed only via clambercloud.com (sideloaded APK), not the
# Play Store, so the release APK must be signed with a stable, private key that
# you keep off version control. Copy this file to `keystore.properties` (which is
# git-ignored) and fill in real values.
#
# Create a keystore once:
#   keytool -genkeypair -v -keystore clambhook-release.jks \
#     -alias clambhook -keyalg RSA -keysize 4096 -validity 10000
#
# `storeFile` is resolved relative to the app module (ui/android/app).
# When keystore.properties is absent, `assembleRelease` still builds but the APK
# is left unsigned.
storeFile=clambhook-release.jks
storePassword=CHANGE_ME
keyAlias=clambhook
keyPassword=CHANGE_ME

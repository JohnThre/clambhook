<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@app_id@</id>
  <name>clambhook</name>
  <summary>Desktop controller for the clambhook daemon</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <description>
    <p>clambhook for Linux manages daemon connectivity, profiles, listeners, and recent event activity from a GTK desktop window.</p>
  </description>
  <launchable type="desktop-id">@app_id@.desktop</launchable>
</component>

<Window
    x:Class="Clambhook.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="clambhook">
    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <Style x:Key="PanelBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <Style x:Key="MetricBorderStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
                <Setter Property="MinHeight" Value="112" />
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <DataTemplate x:Key="DetailRowTemplate">
                <Grid Padding="12,10" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon
                        Glyph="{Binding Glyph}"
                        FontSize="18"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        VerticalAlignment="Top" />

                    <StackPanel Grid.Column="1" Spacing="3">
                        <TextBlock Text="{Binding Primary}" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock
                            Text="{Binding Secondary}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Text="{Binding Meta}"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Border
                        Grid.Column="2"
                        Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                        CornerRadius="8"
                        Padding="8,3"
                        Opacity="{Binding BadgeOpacity}"
                        VerticalAlignment="Top">
                        <TextBlock Text="{Binding Badge}" FontSize="12" />
                    </Border>
                </Grid>
            </DataTemplate>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="20,16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="clambhook" FontSize="24" FontWeight="SemiBold" />
                    <Border
                        x:Name="StatusBadgeBorder"
                        CornerRadius="8"
                        Padding="8,3"
                        VerticalAlignment="Center">
                        <TextBlock x:Name="StatusBadgeText" FontSize="12" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
                <TextBlock x:Name="StatusDetailText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Button Grid.Column="1" x:Name="RefreshButton" Click="RefreshButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72C;" />
                    <TextBlock Text="Refresh" />
                </StackPanel>
            </Button>
            <Button
                Grid.Column="2"
                x:Name="SettingsButton"
                ToolTipService.ToolTip="Settings"
                Click="SettingsButton_Click">
                <FontIcon Glyph="&#xE713;" />
            </Button>
            <Button Grid.Column="3" x:Name="ConnectionButton" Style="{StaticResource AccentButtonStyle}" Click="ConnectionButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon x:Name="ConnectionButtonIcon" />
                    <TextBlock x:Name="ConnectionButtonText" />
                </StackPanel>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="20,0,20,20" Spacing="16">
                <InfoBar
                    x:Name="ErrorInfoBar"
                    IsClosable="False"
                    IsOpen="False"
                    Severity="Error" />

                <InfoBar
                    x:Name="BusyInfoBar"
                    IsClosable="False"
                    IsOpen="False"
                    Severity="Informational">
                    <InfoBar.Content>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ProgressRing x:Name="BusyRing" Width="20" Height="20" IsIndeterminate="True" />
                            <TextBlock x:Name="BusyText" VerticalAlignment="Center" />
                        </StackPanel>
                    </InfoBar.Content>
                </InfoBar>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="10">
                            <TextBlock x:Name="StatusText" FontSize="32" FontWeight="SemiBold" />
                            <TextBlock x:Name="ApiText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="DaemonText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock
                                x:Name="DaemonMessageText"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="10" MinWidth="280">
                            <ComboBox
                                x:Name="ProfilesComboBox"
                                Header="Profile"
                                HorizontalAlignment="Stretch"
                                SelectionChanged="ProfilesComboBox_SelectionChanged" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    x:Name="StartDaemonButton"
                                    HorizontalAlignment="Stretch"
                                    Click="StartDaemonButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE768;" />
                                        <TextBlock Text="Start daemon" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Grid.Column="1"
                                    x:Name="StopDaemonButton"
                                    HorizontalAlignment="Stretch"
                                    Click="StopDaemonButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE769;" />
                                        <TextBlock Text="Stop daemon" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource MetricBorderStyle}">
                        <StackPanel Spacing="6">
                            <FontIcon Glyph="&#xE81E;" HorizontalAlignment="Left" />
                            <TextBlock Text="Connections" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ConnectionsMetricText" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock x:Name="ConnectionsMetricDetailText" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricBorderStyle}">
                        <StackPanel Spacing="6">
                            <FontIcon Glyph="&#xE896;" HorizontalAlignment="Left" />
                            <TextBlock Text="Down" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="DownMetricText" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock x:Name="DownMetricDetailText" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricBorderStyle}">
                        <StackPanel Spacing="6">
                            <FontIcon Glyph="&#xE898;" HorizontalAlignment="Left" />
                            <TextBlock Text="Up" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="UpMetricText" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock x:Name="UpMetricDetailText" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource MetricBorderStyle}">
                        <StackPanel Spacing="6">
                            <FontIcon Glyph="&#xE8A7;" HorizontalAlignment="Left" />
                            <TextBlock Text="Profile" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ProfileMetricText" FontSize="24" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="ProfileMetricDetailText" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource PanelBorderStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Listeners" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock
                                x:Name="ListenersEmptyText"
                                Text="No listeners"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ListView
                                x:Name="ListenersList"
                                ItemTemplate="{StaticResource DetailRowTemplate}"
                                SelectionMode="None" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Recent traffic" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock
                                x:Name="TrafficEmptyText"
                                Text="No traffic history"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ListView
                                x:Name="TrafficList"
                                ItemTemplate="{StaticResource DetailRowTemplate}"
                                SelectionMode="None"
                                MaxHeight="420" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource PanelBorderStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Servers" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock
                                x:Name="ServersEmptyText"
                                Text="No servers in active profile"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ListView
                                x:Name="ServersList"
                                ItemTemplate="{StaticResource DetailRowTemplate}"
                                SelectionMode="None" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Recent logs" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock
                                x:Name="LogsEmptyText"
                                Text="No log events"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ListView
                                x:Name="LogsList"
                                ItemTemplate="{StaticResource DetailRowTemplate}"
                                SelectionMode="None"
                                MaxHeight="320" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <ContentDialog
            x:Name="SettingsDialog"
            Title="Settings"
            PrimaryButtonText="Save"
            CloseButtonText="Cancel"
            DefaultButton="Primary"
            PrimaryButtonClick="SettingsDialog_PrimaryButtonClick">
            <ScrollViewer MaxHeight="620">
                <StackPanel Spacing="12">
                    <TextBlock
                        x:Name="SettingsValidationText"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        TextWrapping="Wrap"
                        Visibility="Collapsed" />
                    <TextBox x:Name="EndpointBox" Header="API endpoint" TextChanged="EndpointBox_TextChanged" />
                    <PasswordBox x:Name="TokenBox" Header="Bearer token" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DaemonPathBox" Header="Daemon executable path" />
                        <Button Grid.Column="1" Content="Browse" VerticalAlignment="Bottom" Click="BrowseDaemonButton_Click" />
                    </Grid>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ConfigPathBox" Header="Config path" />
                        <Button Grid.Column="1" Content="Browse" VerticalAlignment="Bottom" Click="BrowseConfigButton_Click" />
                    </Grid>
                    <NumberBox
                        x:Name="RefreshSecondsBox"
                        Header="Refresh seconds"
                        Minimum="2"
                        Maximum="60"
                        SmallChange="1"
                        SpinButtonPlacementMode="Inline" />
                    <ToggleSwitch x:Name="LaunchDaemonBox" Header="Launch daemon on start" />
                    <ToggleSwitch x:Name="StopDaemonBox" Header="Stop daemon on quit" />
                    <ToggleSwitch x:Name="EventsBox" Header="Use event stream" />
                    <ToggleSwitch x:Name="TrayBox" Header="Minimize to tray" />
                </StackPanel>
            </ScrollViewer>
        </ContentDialog>
    </Grid>
</Window>

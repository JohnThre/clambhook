<Window
    x:Class="Clambhook.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="clambhook">
    <Grid Margin="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2">
                <TextBlock x:Name="StatusText" FontSize="24" FontWeight="SemiBold" />
                <TextBlock x:Name="ApiText" />
                <TextBlock x:Name="ErrorText" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="Wrap" />
            </StackPanel>

            <Button Grid.Column="1" x:Name="RefreshButton" Content="Refresh" Click="RefreshButton_Click" />
            <Button Grid.Column="2" x:Name="ConnectButton" Content="Connect" Click="ConnectButton_Click" />
            <Button Grid.Column="3" x:Name="DisconnectButton" Content="Disconnect" Click="DisconnectButton_Click" />
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Profiles" FontSize="18" FontWeight="SemiBold" />
                        <ComboBox x:Name="ProfilesComboBox" SelectionChanged="ProfilesComboBox_SelectionChanged" Width="280" />
                        <TextBlock x:Name="BandwidthText" />
                        <TextBlock x:Name="ConnectionsText" />

                        <TextBlock Text="Listeners" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,0" />
                        <ListView x:Name="ListenersList" MinHeight="96" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="Daemon" FontSize="18" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="StartDaemonButton" Content="Start daemon" Click="StartDaemonButton_Click" />
                            <Button x:Name="StopDaemonButton" Content="Stop daemon" Click="StopDaemonButton_Click" />
                        </StackPanel>
                        <TextBlock x:Name="DaemonText" TextWrapping="Wrap" />

                        <TextBlock Text="Servers" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,0" />
                        <ListView x:Name="ServersList" MinHeight="160" />
                    </StackPanel>
                </Grid>

                <StackPanel Spacing="8">
                    <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" />
                    <TextBox x:Name="EndpointBox" Header="API endpoint" />
                    <PasswordBox x:Name="TokenBox" Header="Bearer token" />
                    <TextBox x:Name="DaemonPathBox" Header="Daemon executable path" />
                    <TextBox x:Name="ConfigPathBox" Header="Config path" />
                    <TextBox x:Name="RefreshSecondsBox" Header="Refresh seconds" />
                    <CheckBox x:Name="LaunchDaemonBox" Content="Launch daemon on start" />
                    <CheckBox x:Name="StopDaemonBox" Content="Stop daemon on quit" />
                    <CheckBox x:Name="EventsBox" Content="Use event stream" />
                    <CheckBox x:Name="TrayBox" Content="Minimize to tray" />
                    <Button x:Name="SaveSettingsButton" Content="Save settings" Click="SaveSettingsButton_Click" HorizontalAlignment="Left" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Recent logs" FontSize="18" FontWeight="SemiBold" />
                    <ListView x:Name="LogsList" MinHeight="160" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
